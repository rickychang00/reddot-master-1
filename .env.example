# Docker Isolation — change this for every new project
COMPOSE_PROJECT_NAME=reddot_master

# Ports — change if running multiple projects on the same server
FRONTEND_PORT=9002
BACKEND_PORT=8090

# URLs
# Local dev: keep as-is (auto-derived from BACKEND_PORT above)
# Production: change NEXT_PUBLIC_POCKETBASE_URL to your real public PocketBase domain
#             e.g. https://pb.yourproject.com
# IMPORTANT: set this BEFORE uploading any images — it determines the URL stored for every uploaded file
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:${BACKEND_PORT}
# Docker internal URL — do not change (frontend container talks to pb_backend container directly)
POCKETBASE_INTERNAL_URL=http://pb_backend:8080

# Red Dot Payment credentials — get from RDP merchant dashboard
RDP_MID=your_merchant_id_here
RDP_SECRET_KEY=your_secret_key_here

# Default seeded credentials (change after first login)
# PocketBase Superadmin — logs in at http://localhost:{BACKEND_PORT}/_/
#   Email:    superadmin@admin.com
#   Password: SuperAdmin1234!
# App Admin — logs in at http://localhost:{FRONTEND_PORT}/login
#   Email:    admin@admin.com
#   Password: Admin1234!
