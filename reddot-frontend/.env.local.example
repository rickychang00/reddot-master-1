# Local dev environment — copy this file to .env.local and fill in your values
# .env.local is gitignored and never committed

# PocketBase URL for local development
# Must match the BACKEND_PORT in the root .env file (default 8090)
# Change to http://localhost:<your-port> if you use a different port
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# Red Dot Payment credentials — get from RDP merchant dashboard
# Use sandbox credentials for local dev, production credentials for live
RDP_MID=your_merchant_id_here
RDP_SECRET_KEY=your_secret_key_here
